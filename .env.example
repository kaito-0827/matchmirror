# バックエンドAPIのURL（未設定時は http://127.0.0.1:8000）
VITE_API_URL=http://127.0.0.1:8000

# Firebase Authentication 設定（Firebaseコンソール > プロジェクト設定 > マイアプリ）
# これらが未設定の場合、アプリはログイン機能なしのゲスト動作のみになる
# （診断・レポート・質問生成は引き続き利用可。保存機能はログイン有効時のみ）。
# すべて設定するとメール/パスワード・Googleログインが有効になる。
# ※ Firebaseコンソールで「Google」「メール/パスワード」プロバイダを有効化し、
#    承認済みドメインに本番URLとlocalhostを追加すること。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
