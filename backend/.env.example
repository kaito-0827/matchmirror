# ==========================================
# MatchMirror Backend 環境変数
# ==========================================

# Google Gemini API（必須）
# https://aistudio.google.com で取得
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud プロジェクト（Firestore使用時に必須）
GOOGLE_CLOUD_PROJECT=google-hackthon

# ローカル開発でFirestoreを使う場合のみ設定（Cloud Runでは不要）
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firestoreエミュレーター（ローカルテスト用・通常は空）
FIRESTORE_EMULATOR_HOST=

# 環境（development / production）
ENVIRONMENT=development

# CORS許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
